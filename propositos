<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8"/>
<meta name="apple-mobile-web-app-capable" content="yes"/>
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent"/>
<meta name="description" content="Propósitos Interligados – Registo de horas para profissionais de obra"/>
<meta name="theme-color" content="#1a0533"/>
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1,user-scalable=no"/>
<title>Propósitos Interligados – Registo de Horas</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;600;700;800&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&display=swap" rel="stylesheet"/>
<style>
:root{
  --bg:#0e0220;
  --surface:#1a0533;
  --surface2:#240d42;
  --surface3:#2e1550;
  --accent:#b06cff;
  --accent2:#7c3aed;
  --gold:#f0c060;
  --green:#22c55e;
  --red:#f87171;
  --text:#f0e8ff;
  --muted:#8b7aa8;
  --border:rgba(176,108,255,.18);
  --radius:16px;
  --radius-sm:10px;
  --shadow:0 8px 32px rgba(0,0,0,.45);
  --tab-h:62px;
}
*{box-sizing:border-box;margin:0;padding:0;-webkit-tap-highlight-color:transparent}
html,body{height:100%;background:var(--bg);color:var(--text);font-family:'DM Sans',sans-serif;overflow:hidden}
body{display:flex;flex-direction:column}

/* ── HEADER ─────────────────────────────── */
#app-header{
  position:relative;
  display:flex;align-items:center;gap:12px;
  padding:14px 16px 10px;
  background:var(--surface);
  border-bottom:1px solid var(--border);
  flex-shrink:0;
  z-index:10;
}
#app-header::after{
  content:'';position:absolute;bottom:0;left:0;right:0;height:1px;
  background:linear-gradient(90deg,transparent,var(--accent),transparent);opacity:.4;
}

/* Profile photo */
#profile-pic-wrap{
  position:relative;width:52px;height:52px;flex-shrink:0;cursor:pointer;
}
#profile-pic-wrap img{
  width:52px;height:52px;border-radius:50%;object-fit:cover;
  border:2px solid var(--accent);
  display:block;
}
#profile-pic-wrap .no-photo{
  width:52px;height:52px;border-radius:50%;
  background:var(--surface2);
  border:2px dashed var(--accent);
  display:flex;align-items:center;justify-content:center;
  font-size:22px;
}
#profile-pic-wrap .edit-overlay{
  position:absolute;bottom:-2px;right:-2px;
  width:20px;height:20px;border-radius:50%;
  background:var(--accent2);
  display:flex;align-items:center;justify-content:center;
  font-size:11px;border:2px solid var(--bg);
  opacity:0;transition:opacity .2s;
}
#profile-pic-wrap:hover .edit-overlay{opacity:1}
#photo-input{display:none}

/* Header text */
#header-info{flex:1;min-width:0}
#header-name{
  font-family:'Syne',sans-serif;font-weight:700;font-size:15px;
  color:var(--text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
  display:flex;align-items:center;gap:6px;
}
#header-name .edit-btn{
  font-size:12px;cursor:pointer;color:var(--muted);
  padding:2px 4px;border-radius:4px;transition:color .2s;flex-shrink:0;
}
#header-name .edit-btn:hover{color:var(--accent)}
#header-site{
  font-size:12px;color:var(--accent);
  white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
  display:flex;align-items:center;gap:6px;margin-top:2px;
}
#header-site .edit-btn{
  font-size:11px;cursor:pointer;color:var(--muted);
  padding:1px 4px;border-radius:4px;transition:color .2s;flex-shrink:0;
}
#header-site .edit-btn:hover{color:var(--accent)}

/* Brand logo */
#brand-logo{
  font-family:'Syne',sans-serif;font-weight:800;font-size:11px;
  text-align:right;color:var(--muted);line-height:1.25;letter-spacing:.03em;
  flex-shrink:0;
}
#brand-logo span{display:block;color:var(--accent);font-size:9px;margin-top:1px;letter-spacing:.08em}

/* ── INLINE EDIT FIELDS ──────────────────── */
.inline-edit-row{display:flex;align-items:center;gap:6px;margin-top:4px}
.inline-edit-row input{
  font-family:'DM Sans',sans-serif;font-size:13px;
  background:var(--surface2);color:var(--text);
  border:1px solid var(--accent);border-radius:6px;
  padding:4px 8px;flex:1;outline:none;
}
.inline-edit-row button{
  font-size:11px;padding:4px 10px;border-radius:6px;
  border:none;cursor:pointer;font-family:'DM Sans',sans-serif;
}
.inline-edit-row .btn-save{background:var(--accent2);color:#fff}
.inline-edit-row .btn-cancel{background:var(--surface3);color:var(--muted)}

/* ── TABS ────────────────────────────────── */
#tab-bar{
  display:flex;
  background:var(--surface);
  border-bottom:1px solid var(--border);
  flex-shrink:0;
}
.tab-btn{
  flex:1;display:flex;flex-direction:column;align-items:center;justify-content:center;
  gap:3px;padding:8px 4px;cursor:pointer;
  font-family:'Syne',sans-serif;font-size:9px;font-weight:700;
  letter-spacing:.06em;text-transform:uppercase;
  color:var(--muted);background:transparent;border:none;
  position:relative;transition:color .2s;
}
.tab-btn .tab-icon{font-size:17px;transition:transform .2s}
.tab-btn.active{color:var(--accent)}
.tab-btn.active .tab-icon{transform:scale(1.15)}
.tab-btn::after{
  content:'';position:absolute;bottom:0;left:20%;right:20%;height:2px;
  background:var(--accent);border-radius:2px 2px 0 0;
  transform:scaleX(0);transition:transform .2s;
}
.tab-btn.active::after{transform:scaleX(1)}
#badge-hist{
  position:absolute;top:6px;right:calc(50% - 18px);
  min-width:16px;height:16px;border-radius:8px;
  background:var(--accent2);color:#fff;font-size:9px;font-weight:700;
  display:none;align-items:center;justify-content:center;padding:0 4px;
  font-family:'Syne',sans-serif;
}

/* ── PAGES ───────────────────────────────── */
#pages{flex:1;overflow:hidden;position:relative}
.page{
  position:absolute;inset:0;overflow-y:auto;
  display:none;padding:16px 14px calc(var(--tab-h) + 16px);
}
.page.active{display:block}
/* custom scrollbar */
.page::-webkit-scrollbar{width:3px}
.page::-webkit-scrollbar-track{background:transparent}
.page::-webkit-scrollbar-thumb{background:var(--accent2);border-radius:2px}

/* ── CARDS ───────────────────────────────── */
.card{
  background:var(--surface);
  border:1px solid var(--border);
  border-radius:var(--radius);
  padding:16px;margin-bottom:14px;
  box-shadow:var(--shadow);
  position:relative;overflow:hidden;
}
.card::before{
  content:'';position:absolute;top:0;left:0;right:0;height:2px;
  background:linear-gradient(90deg,var(--accent2),var(--accent),transparent);
  opacity:.6;
}
.card-title{
  font-family:'Syne',sans-serif;font-weight:700;font-size:12px;
  letter-spacing:.08em;text-transform:uppercase;color:var(--accent);
  margin-bottom:14px;display:flex;align-items:center;gap:6px;
}

/* ── DATE STRIP ──────────────────────────── */
#date-strip{
  display:flex;align-items:center;justify-content:space-between;
  background:var(--surface2);border-radius:var(--radius-sm);
  padding:10px 14px;margin-bottom:14px;
  border:1px solid var(--border);
}
#date-strip .date-label{
  font-family:'Syne',sans-serif;font-weight:700;font-size:15px;color:var(--text);
}
#date-strip .date-sub{font-size:11px;color:var(--muted);margin-top:1px}
#date-input-wrap input[type=date]{
  background:transparent;border:none;color:var(--accent);
  font-family:'DM Sans',sans-serif;font-size:12px;cursor:pointer;outline:none;
  color-scheme:dark;
}

/* ── TIME FIELDS ─────────────────────────── */
.time-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:10px}
.time-field{
  background:var(--surface2);border-radius:var(--radius-sm);
  border:1px solid var(--border);padding:10px 12px;
  cursor:pointer;transition:border-color .2s,background .2s;
  position:relative;
}
.time-field:hover{border-color:var(--accent);background:var(--surface3)}
.time-field.has-value{border-color:rgba(176,108,255,.4)}
.time-field-label{
  font-size:10px;color:var(--muted);font-weight:500;
  letter-spacing:.04em;text-transform:uppercase;margin-bottom:4px;
}
.time-field-value{
  font-family:'Syne',sans-serif;font-weight:700;font-size:20px;color:var(--text);
  letter-spacing:.04em;
}
.time-field-value.empty{color:var(--muted);font-size:16px;font-weight:400}
.time-auto-btn{
  position:absolute;top:8px;right:8px;
  background:var(--accent2);color:#fff;border:none;
  border-radius:6px;padding:3px 7px;font-size:10px;
  cursor:pointer;font-family:'Syne',sans-serif;font-weight:700;
  transition:background .15s,transform .1s;letter-spacing:.04em;
}
.time-auto-btn:hover{background:var(--accent);transform:scale(1.05)}
.time-auto-btn:active{transform:scale(.95)}

/* ── SUMMARY ROW ─────────────────────────── */
.summary-row{
  display:grid;grid-template-columns:repeat(3,1fr);gap:8px;margin-top:10px;
}
.sum-box{
  background:var(--surface2);border-radius:var(--radius-sm);
  padding:10px;text-align:center;border:1px solid var(--border);
}
.sum-box .sum-val{
  font-family:'Syne',sans-serif;font-weight:800;font-size:18px;color:var(--gold);
}
.sum-box .sum-lbl{font-size:10px;color:var(--muted);margin-top:2px;letter-spacing:.04em}

/* ── OBS + ACTIONS ───────────────────────── */
#obs-input{
  width:100%;background:var(--surface2);border:1px solid var(--border);
  border-radius:var(--radius-sm);padding:10px 12px;
  color:var(--text);font-family:'DM Sans',sans-serif;font-size:14px;
  resize:none;outline:none;transition:border-color .2s;min-height:64px;
}
#obs-input:focus{border-color:var(--accent)}

.btn-row{display:flex;gap:10px;margin-top:12px}
.btn-wa{
  flex:0 0 auto;display:flex;align-items:center;justify-content:center;gap:6px;
  background:#25d366;color:#fff;border:none;border-radius:var(--radius-sm);
  padding:12px 14px;font-family:'Syne',sans-serif;font-weight:700;font-size:12px;
  cursor:pointer;transition:background .2s,transform .1s;white-space:nowrap;
}
.btn-wa:hover{background:#1ebe5a}
.btn-save-main{
  flex:1;display:flex;align-items:center;justify-content:center;gap:8px;
  background:linear-gradient(135deg,var(--accent2),var(--accent));
  color:#fff;border:none;border-radius:var(--radius-sm);
  padding:14px;font-family:'Syne',sans-serif;font-weight:800;font-size:14px;
  letter-spacing:.04em;cursor:pointer;
  transition:opacity .2s,transform .1s;box-shadow:0 4px 16px rgba(124,58,237,.4);
}
.btn-save-main:hover{opacity:.9}
.btn-save-main:active{transform:scale(.97)}

/* ── DRUM PICKER MODAL ───────────────────── */
#drum-overlay{
  position:fixed;inset:0;background:rgba(0,0,0,.75);
  z-index:200;display:none;align-items:flex-end;justify-content:center;
  backdrop-filter:blur(6px);
}
#drum-overlay.open{display:flex}
#drum-sheet{
  background:var(--surface);border-radius:24px 24px 0 0;
  padding:0 0 32px;width:100%;max-width:480px;
  border-top:1px solid var(--border);
  box-shadow:0 -8px 40px rgba(0,0,0,.6);
}
#drum-header{
  padding:18px 20px 14px;display:flex;align-items:center;justify-content:space-between;
  border-bottom:1px solid var(--border);
}
#drum-title{
  font-family:'Syne',sans-serif;font-weight:800;font-size:16px;color:var(--text);
}
#drum-close{
  background:var(--surface2);border:none;color:var(--muted);
  border-radius:50%;width:32px;height:32px;
  display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:18px;
}
#drum-pickers{display:flex;justify-content:center;align-items:center;gap:0;padding:16px 20px}
.drum-col{display:flex;flex-direction:column;align-items:center;flex:1}
.drum-col-label{font-size:11px;color:var(--muted);letter-spacing:.08em;margin-bottom:8px;text-transform:uppercase}
.drum-scroll-wrap{
  position:relative;height:180px;overflow:hidden;
  width:90px;cursor:grab;
}
.drum-scroll-wrap:active{cursor:grabbing}
.drum-gradient-top,.drum-gradient-bot{
  position:absolute;left:0;right:0;height:60px;z-index:2;pointer-events:none;
}
.drum-gradient-top{top:0;background:linear-gradient(to bottom,var(--surface),transparent)}
.drum-gradient-bot{bottom:0;background:linear-gradient(to top,var(--surface),transparent)}
.drum-selector{
  position:absolute;top:50%;left:6px;right:6px;height:44px;
  transform:translateY(-50%);
  border:2px solid var(--accent);border-radius:10px;
  background:rgba(176,108,255,.08);z-index:1;pointer-events:none;
}
.drum-list{
  display:flex;flex-direction:column;align-items:center;
  padding-top:68px;padding-bottom:68px;
  transition:transform .15s cubic-bezier(.25,.46,.45,.94);
}
.drum-item{
  height:44px;display:flex;align-items:center;justify-content:center;
  font-family:'Syne',sans-serif;font-weight:700;font-size:24px;
  color:var(--muted);transition:color .15s,font-size .15s;
  width:90px;user-select:none;
}
.drum-item.selected{color:var(--text);font-size:26px}
.drum-sep{
  font-family:'Syne',sans-serif;font-weight:800;font-size:32px;
  color:var(--accent);align-self:center;padding:0 8px;margin-top:20px;
}
#drum-actions{
  display:flex;gap:10px;padding:0 20px;margin-top:8px;
}
#drum-now{
  flex:0 0 auto;background:var(--surface2);border:1px solid var(--border);
  color:var(--muted);border-radius:var(--radius-sm);
  padding:12px 14px;font-family:'Syne',sans-serif;font-weight:700;font-size:12px;
  cursor:pointer;transition:border-color .2s,color .2s;white-space:nowrap;
}
#drum-now:hover{border-color:var(--accent);color:var(--accent)}
#drum-confirm{
  flex:1;background:linear-gradient(135deg,var(--accent2),var(--accent));
  color:#fff;border:none;border-radius:var(--radius-sm);
  padding:14px;font-family:'Syne',sans-serif;font-weight:800;font-size:14px;
  cursor:pointer;transition:opacity .2s;
}
#drum-confirm:hover{opacity:.9}

/* ── HISTORY ─────────────────────────────── */
.hist-empty{
  text-align:center;padding:40px 20px;color:var(--muted);
  font-size:14px;
}
.hist-empty span{display:block;font-size:40px;margin-bottom:12px}
.hist-filters{
  display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap;align-items:flex-end;
}
.hist-filters input[type=date]{
  background:var(--surface2);border:1px solid var(--border);
  color:var(--text);border-radius:var(--radius-sm);padding:8px 10px;
  font-family:'DM Sans',sans-serif;font-size:13px;outline:none;
  color-scheme:dark;flex:1;min-width:120px;
}
.hist-filters input[type=text]{
  background:var(--surface2);border:1px solid var(--border);
  color:var(--text);border-radius:var(--radius-sm);padding:8px 10px;
  font-family:'DM Sans',sans-serif;font-size:13px;outline:none;flex:1;min-width:120px;
}
.hist-filter-btn{
  background:var(--accent2);color:#fff;border:none;border-radius:var(--radius-sm);
  padding:8px 14px;font-family:'Syne',sans-serif;font-weight:700;font-size:12px;
  cursor:pointer;white-space:nowrap;
}
.hist-entry{
  background:var(--surface);border:1px solid var(--border);
  border-radius:var(--radius-sm);padding:12px 14px;margin-bottom:10px;
  position:relative;overflow:hidden;
}
.hist-entry::before{
  content:'';position:absolute;left:0;top:0;bottom:0;width:3px;
  background:linear-gradient(to bottom,var(--accent2),var(--accent));
}
.hist-entry-top{display:flex;justify-content:space-between;align-items:flex-start;gap:8px}
.hist-date{
  font-family:'Syne',sans-serif;font-weight:700;font-size:13px;color:var(--text);
}
.hist-hours{
  font-family:'Syne',sans-serif;font-weight:800;font-size:18px;color:var(--gold);
  white-space:nowrap;
}
.hist-times{
  font-size:11px;color:var(--muted);margin-top:4px;line-height:1.6;
}
.hist-obs{
  font-size:12px;color:var(--accent);margin-top:6px;
  padding:4px 8px;background:rgba(176,108,255,.08);border-radius:6px;
}
.hist-del{
  position:absolute;top:10px;right:10px;background:none;border:none;
  color:var(--muted);cursor:pointer;font-size:14px;padding:4px;
  transition:color .2s;
}
.hist-del:hover{color:var(--red)}

/* ── EXPORT PAGE ─────────────────────────── */
.export-section{margin-bottom:14px}
.export-btn{
  width:100%;display:flex;align-items:center;gap:14px;
  background:var(--surface2);border:1px solid var(--border);
  border-radius:var(--radius-sm);padding:14px 16px;
  cursor:pointer;transition:border-color .2s,background .2s;
  text-align:left;
}
.export-btn:hover{border-color:var(--accent);background:var(--surface3)}
.export-btn .exp-icon{font-size:24px;flex-shrink:0}
.export-btn .exp-title{
  font-family:'Syne',sans-serif;font-weight:700;font-size:13px;color:var(--text);
}
.export-btn .exp-sub{font-size:11px;color:var(--muted);margin-top:2px}
.export-btn .exp-action{
  margin-left:auto;background:var(--accent2);color:#fff;border:none;
  border-radius:6px;padding:6px 12px;font-family:'Syne',sans-serif;font-weight:700;font-size:11px;
  cursor:pointer;
}
.exp-wa .exp-action{background:#25d366}
.danger-btn{
  width:100%;display:flex;align-items:center;gap:14px;
  background:rgba(248,113,113,.07);border:1px solid rgba(248,113,113,.2);
  border-radius:var(--radius-sm);padding:14px 16px;
  cursor:pointer;transition:border-color .2s,background .2s;
  text-align:left;
}
.danger-btn:hover{border-color:var(--red);background:rgba(248,113,113,.12)}
.danger-btn .exp-icon{font-size:24px;flex-shrink:0}
.danger-btn .exp-title{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;color:var(--red)}
.danger-btn .exp-sub{font-size:11px;color:var(--muted);margin-top:2px}
.danger-btn .exp-action{
  margin-left:auto;background:var(--red);color:#fff;border:none;
  border-radius:6px;padding:6px 12px;font-family:'Syne',sans-serif;font-weight:700;font-size:11px;
  cursor:pointer;
}

/* ── ALARM CARD ──────────────────────────── */
.alarm-card{background:var(--surface2);border:1px solid var(--border);border-radius:var(--radius-sm);padding:14px}
.alarm-row{display:flex;align-items:center;justify-content:space-between;gap:10px}
.alarm-info .alarm-title{font-family:'Syne',sans-serif;font-weight:700;font-size:13px;color:var(--text)}
.alarm-info .alarm-sub{font-size:11px;color:var(--muted);margin-top:2px}
/* Toggle */
.toggle{position:relative;display:inline-block;width:44px;height:24px;flex-shrink:0}
.toggle input{opacity:0;width:0;height:0}
.toggle-slider{
  position:absolute;inset:0;border-radius:24px;
  background:var(--surface3);cursor:pointer;transition:.2s;
}
.toggle-slider::before{
  content:'';position:absolute;height:18px;width:18px;left:3px;bottom:3px;
  border-radius:50%;background:var(--muted);transition:.2s;
}
.toggle input:checked + .toggle-slider{background:var(--accent2)}
.toggle input:checked + .toggle-slider::before{transform:translateX(20px);background:#fff}

/* ── ALARM BANNER ────────────────────────── */
#alarm-banner{
  position:fixed;top:0;left:0;right:0;z-index:300;
  background:linear-gradient(135deg,#1a0533,#2d1057);
  border-bottom:2px solid var(--accent);
  padding:14px 16px;
  transform:translateY(-100%);transition:transform .4s cubic-bezier(.34,1.56,.64,1);
  box-shadow:0 8px 32px rgba(0,0,0,.5);
}
#alarm-banner.show{transform:translateY(0)}
#alarm-banner-title{
  font-family:'Syne',sans-serif;font-weight:800;font-size:15px;color:var(--text);
  display:flex;align-items:center;gap:8px;margin-bottom:10px;
}
#alarm-banner-btns{display:flex;gap:8px;flex-wrap:wrap}
#alarm-banner-btns button{
  border:none;border-radius:8px;padding:8px 12px;
  font-family:'Syne',sans-serif;font-weight:700;font-size:11px;
  cursor:pointer;transition:opacity .2s;
}
#alarm-banner-btns button:hover{opacity:.8}
.ab-snooze{background:var(--surface3);color:var(--muted)}
.ab-register{background:var(--accent2);color:#fff}
.ab-silence{background:rgba(248,113,113,.15);color:var(--red)}

/* ── TOAST ───────────────────────────────── */
#toast{
  position:fixed;bottom:calc(var(--tab-h) + 16px);left:50%;
  transform:translateX(-50%) translateY(20px);
  background:var(--surface3);color:var(--text);
  border:1px solid var(--border);border-radius:40px;
  padding:10px 20px;font-size:13px;font-weight:500;
