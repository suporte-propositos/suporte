<div id="toast"></div>

<script>
// ═══════════════════════════════════════════════════
// DATA
// ═══════════════════════════════════════════════════
const KEY_RECORDS = 'pi_records_v2';
const KEY_PROFILE = 'pi_profile_v2';
const KEY_ALARM   = 'pi_alarm_v2';
const KEY_SILENCE = 'pi_alarm_silence';
const WA_NUMBER   = '351912345678'; // fallback

let records  = JSON.parse(localStorage.getItem(KEY_RECORDS)  || '[]');
let profile  = JSON.parse(localStorage.getItem(KEY_PROFILE)  || '{}');
let alarmCfg = JSON.parse(localStorage.getItem(KEY_ALARM)    || '{"active":true}');

// current day times
let times = {entry:'',lunchout:'',lunchin:'',exit:''};
let currentDate = todayISO();

function todayISO(){
  const d=new Date();
  return d.toISOString().slice(0,10);
}
function saveRecords(){ localStorage.setItem(KEY_RECORDS, JSON.stringify(records)); }
function saveProfile_(){
  localStorage.setItem(KEY_PROFILE, JSON.stringify(profile));
  applyProfile();
}
function saveAlarm(){ localStorage.setItem(KEY_ALARM, JSON.stringify(alarmCfg)); }

// ═══════════════════════════════════════════════════
// INIT
// ═══════════════════════════════════════════════════
window.addEventListener('DOMContentLoaded', ()=>{
  setDate(todayISO());
  applyProfile();
  loadDayData(currentDate);
  updateBadge();
  renderHistory();
  initAlarm();
  updateAlarmStatus();

  // First-run: open profile if no name
  if(!profile.name){ setTimeout(openProfileModal,600); }
});

function setDate(iso){
  currentDate = iso;
  document.getElementById('date-input').value = iso;
  const d = new Date(iso+'T12:00:00');
  const days = ['Domingo','Segunda','Terça','Quarta','Quinta','Sexta','Sábado'];
  const months = ['Jan','Fev','Mar','Abr','Mai','Jun','Jul','Ago','Set','Out','Nov','Dez'];
  document.getElementById('date-display').textContent =
    `${String(d.getDate()).padStart(2,'0')} ${months[d.getMonth()]} ${d.getFullYear()}`;
  document.getElementById('date-weekday').textContent = days[d.getDay()];
}
function onDateChange(){
  const v = document.getElementById('date-input').value;
  if(v){ setDate(v); loadDayData(v); }
}

function loadDayData(iso){
  const rec = records.find(r=>r.date===iso);
  times = rec
    ? {entry:rec.entry||'',lunchout:rec.lunchout||'',lunchin:rec.lunchin||'',exit:rec.exit||''}
    : {entry:'',lunchout:'',lunchin:'',exit:''};
  document.getElementById('obs-input').value = rec?.obs||'';
  renderTimes();
}

// ═══════════════════════════════════════════════════
// PROFILE
// ═══════════════════════════════════════════════════
function applyProfile(){
  const name = profile.name || '—';
  const site = profile.site || 'Nome / Local da obra';
  document.getElementById('header-name-text').textContent = name;
  document.getElementById('header-site-text').textContent = site;

  if(profile.photo){
    document.getElementById('header-photo').src = profile.photo;
    document.getElementById('header-photo').style.display='block';
    document.getElementById('header-no-photo').style.display='none';
    document.getElementById('pm-photo').src = profile.photo;
    document.getElementById('pm-photo').style.display='block';
    document.getElementById('pm-no-photo').style.display='none';
  } else {
    document.getElementById('header-photo').style.display='none';
    document.getElementById('header-no-photo').style.display='flex';
    document.getElementById('pm-photo').style.display='none';
    document.getElementById('pm-no-photo').style.display='flex';
  }
}

function openProfileModal(){
  document.getElementById('pm-name').value = profile.name||'';
  document.getElementById('pm-site').value = profile.site||'';
  document.getElementById('pm-wa').value   = profile.wa||'';
  if(profile.photo){
    document.getElementById('pm-photo').src = profile.photo;
    document.getElementById('pm-photo').style.display='block';
    document.getElementById('pm-no-photo').style.display='none';
  } else {
    document.getElementById('pm-photo').style.display='none';
    document.getElementById('pm-no-photo').style.display='flex';
  }
  document.getElementById('profile-modal-overlay').classList.add('open');
}
function closeProfileModal(){
  document.getElementById('profile-modal-overlay').classList.remove('open');
}
function profileOverlayClick(e){
  if(e.target.id==='profile-modal-overlay') closeProfileModal();
}
function saveProfile(){
  profile.name = document.getElementById('pm-name').value.trim() || profile.name;
  profile.site = document.getElementById('pm-site').value.trim() || profile.site;
  profile.wa   = document.getElementById('pm-wa').value.trim()   || profile.wa;
  saveProfile_();
  closeProfileModal();
  showToast('✅ Perfil guardado!');
}
function handlePhotoUpload(input){
  const file = input.files[0];
  if(!file) return;
  const reader = new FileReader();
  reader.onload = e=>{
    profile.photo = e.target.result;
    saveProfile_();
  };
  reader.readAsDataURL(file);
}

// ── Inline edit name / site ───────────────────────
function startEditName(){
  document.getElementById('header-name').style.display='none';
  document.getElementById('header-name-edit').style.display='flex';
  document.getElementById('name-edit-input').value = profile.name||'';
  document.getElementById('name-edit-input').focus();
}
function cancelEditName(){
  document.getElementById('header-name').style.display='flex';
  document.getElementById('header-name-edit').style.display='none';
}
function saveEditName(){
  const v = document.getElementById('name-edit-input').value.trim();
  if(v){ profile.name=v; saveProfile_(); }
  cancelEditName();
  showToast('✅ Nome atualizado');
}

function startEditSite(){
  document.getElementById('header-site').style.display='none';
  document.getElementById('header-site-edit').style.display='flex';
  document.getElementById('site-edit-input').value = profile.site||'';
  document.getElementById('site-edit-input').focus();
}
function cancelEditSite(){
  document.getElementById('header-site').style.display='flex';
  document.getElementById('header-site-edit').style.display='none';
}
function saveEditSite(){
  const v = document.getElementById('site-edit-input').value.trim();
  if(v){ profile.site=v; saveProfile_(); }
  cancelEditSite();
  showToast('✅ Local atualizado');
}

// ═══════════════════════════════════════════════════
// TIMES
// ═══════════════════════════════════════════════════
const timeKeys = ['entry','lunchout','lunchin','exit'];
const timeLabels = {entry:'Entrada',lunchout:'Saída almoço',lunchin:'Retorno almoço',exit:'Saída final'};

function roundTo5(h,m){
  const r = Math.round(m/5)*5;
  if(r===60) return {h:(h+1)%24,m:0};
  return {h,m:r};
}
function nowRounded(){
  const n=new Date();
  return roundTo5(n.getHours(),n.getMinutes());
}
function autoTime(key, ev){
  ev && ev.stopPropagation();
  const {h,m}=nowRounded();
  times[key]=`${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
  renderTimes();
  showToast(`⚡ ${timeLabels[key]} → ${times[key]}`);
}
function renderTimes(){
  timeKeys.forEach(k=>{
    const el = document.getElementById('tv-'+k);
    const tf = document.getElementById('tf-'+k);
    if(times[k]){
      el.textContent=times[k];
      el.classList.remove('empty');
      tf.classList.add('has-value');
    } else {
      el.textContent='--:--';
      el.classList.add('empty');
      tf.classList.remove('has-value');
    }
  });
  calcSummary();
}
function calcSummary(){
  const parse=t=>{if(!t)return null;const[h,m]=t.split(':').map(Number);return h*60+m};
  const e=parse(times.entry),lo=parse(times.lunchout),li=parse(times.lunchin),x=parse(times.exit);
  const fmt=min=>{if(min===null||min<0)return '--:--';return `${String(Math.floor(min/60)).padStart(2,'0')}:${String(min%60).padStart(2,'0')}`};
  const totalSpan=(e!==null&&x!==null)?x-e:null;
  const lunch=(lo!==null&&li!==null)?li-lo:null;
  const worked=(totalSpan!==null&&lunch!==null)?totalSpan-lunch:totalSpan;
  document.getElementById('sum-work').textContent=fmt(totalSpan);
  document.getElementById('sum-lunch').textContent=fmt(lunch);
  document.getElementById('sum-total').textContent=fmt(worked);
}

// ═══════════════════════════════════════════════════
// DRUM PICKER
// ═══════════════════════════════════════════════════
let drumField=null, drumH=0, drumM=0;
const ITEM_H=44;
const HOURS=[...Array(24)].map((_,i)=>String(i).padStart(2,'0'));
const MINS=[0,5,10,15,20,25,30,35,40,45,50,55].map(m=>String(m).padStart(2,'0'));

function buildDrumList(listEl, items, selectedIdx){
  listEl.innerHTML='';
  items.forEach((v,i)=>{
    const d=document.createElement('div');
    d.className='drum-item'+(i===selectedIdx?' selected':'');
    d.textContent=v;
    listEl.appendChild(d);
  });
}
function setDrumScroll(wrapId, listEl, idx, animate){
  const offset = idx * ITEM_H;
  if(animate){
    listEl.style.transition='transform .25s cubic-bezier(.25,.46,.45,.94)';
  } else {
    listEl.style.transition='none';
  }
  listEl.style.transform=`translateY(-${offset}px)`;
  // Update selected class
  [...listEl.children].forEach((c,i)=>c.classList.toggle('selected',i===idx));
}

function initDrumScroll(wrapId, listEl, items, initialIdx, onSelect){
  let startY=0, currentY=0, startIdx=initialIdx, isDragging=false;

  const go=(y, animate)=>{
    let newIdx = startIdx + Math.round((startY-y)/ITEM_H);
    newIdx = Math.max(0, Math.min(items.length-1, newIdx));
    setDrumScroll(wrapId, listEl, newIdx, animate);
    return newIdx;
  };

  const wrap=document.getElementById(wrapId);

  wrap.addEventListener('touchstart',e=>{
    startY=e.touches[0].clientY;
    currentY=startY;
    startIdx=getCurrentIdx(listEl,items);
    isDragging=true;
  },{passive:true});
  wrap.addEventListener('touchmove',e=>{
    if(!isDragging)return;
    currentY=e.touches[0].clientY;
    go(currentY,false);
  },{passive:true});
  wrap.addEventListener('touchend',()=>{
    if(!isDragging)return;
    isDragging=false;
    const idx=go(currentY,true);
    startIdx=idx;
    onSelect(idx);
  });
  wrap.addEventListener('mousedown',e=>{
    startY=e.clientY;currentY=startY;
    startIdx=getCurrentIdx(listEl,items);
    isDragging=true;
  });
  window.addEventListener('mousemove',e=>{
    if(!isDragging)return;
    currentY=e.clientY;
    go(currentY,false);
  });
  window.addEventListener('mouseup',()=>{
    if(!isDragging)return;
    isDragging=false;
    const idx=go(currentY,true);
    startIdx=idx;
    onSelect(idx);
  });
  wrap.addEventListener('wheel',e=>{
    e.preventDefault();
    const ci=getCurrentIdx(listEl,items);
    const ni=Math.max(0,Math.min(items.length-1,ci+(e.deltaY>0?1:-1)));
    setDrumScroll(wrapId,listEl,ni,true);
    onSelect(ni);
  },{passive:false});
}
function getCurrentIdx(listEl, items){
  const t=listEl.style.transform;
  const m=t.match(/translateY\(-(\d+(?:\.\d+)?)px\)/);
  if(!m)return 0;
  return Math.min(items.length-1,Math.max(0,Math.round(Number(m[1])/ITEM_H)));
}

function openDrum(field){
  drumField=field;
  const cur=times[field]||'';
  let h=new Date().getHours(), m=new Date().getMinutes();
  if(cur){ [h,m]=cur.split(':').map(Number); }
  // round m to nearest 5
  m=Math.round(m/5)*5;if(m===60){m=0;h=(h+1)%24;}
  drumH=h; drumM=m;

  document.getElementById('drum-title').textContent=timeLabels[field];

  const hList=document.getElementById('drum-h-list');
  const mList=document.getElementById('drum-m-list');
  buildDrumList(hList,HOURS,h);
  buildDrumList(mList,MINS,m/5);
  setTimeout(()=>{
    setDrumScroll('drum-h-wrap',hList,h,false);
    setDrumScroll('drum-m-wrap',mList,m/5,false);
    initDrumScroll('drum-h-wrap',hList,HOURS,h,idx=>{ drumH=idx; });
    initDrumScroll('drum-m-wrap',mList,MINS,m/5,idx=>{ drumM=idx*5; });
  },50);

  document.getElementById('drum-overlay').classList.add('open');
}
function closeDrum(){ document.getElementById('drum-overlay').classList.remove('open'); }
function drumOverlayClick(e){ if(e.target.id==='drum-overlay') closeDrum(); }
function drumSetNow(){
  const {h,m}=nowRounded();
  drumH=h; drumM=m;
  const hList=document.getElementById('drum-h-list');
  const mList=document.getElementById('drum-m-list');
  setDrumScroll('drum-h-wrap',hList,h,true);
  setDrumScroll('drum-m-wrap',mList,m/5,true);
  [...hList.children].forEach((c,i)=>c.classList.toggle('selected',i===h));
  [...mList.children].forEach((c,i)=>c.classList.toggle('selected',i===m/5));
}
function drumConfirm(){
  times[drumField]=`${String(drumH).padStart(2,'0')}:${String(drumM).padStart(2,'0')}`;
  renderTimes();
  closeDrum();
}

// ═══════════════════════════════════════════════════
// SAVE RECORD
// ═══════════════════════════════════════════════════
function saveRecord(){
  const obs = document.getElementById('obs-input').value.trim();
  const idx = records.findIndex(r=>r.date===currentDate);
  const rec = {
    date:currentDate,
    name:profile.name||'—',
    site:profile.site||'—',
    entry:times.entry, lunchout:times.lunchout,
    lunchin:times.lunchin, exit:times.exit,
    obs
  };
  if(idx>=0) records[idx]=rec; else records.unshift(rec);
  saveRecords();
  updateBadge();
  renderHistory();
  showToast('✅ Guardado!');
}

// ═══════════════════════════════════════════════════
// HISTORY
// ═══════════════════════════════════════════════════
function updateBadge(){
  const b=document.getElementById('badge-hist');
  const n=records.length;
  b.textContent=n;
  b.style.display=n>0?'flex':'none';
}
function renderHistory(){
  const from=document.getElementById('filter-from').value;
  const to=document.getElementById('filter-to').value;
  const prof=document.getElementById('filter-prof').value.trim().toLowerCase();
  let list=[...records].sort((a,b)=>b.date.localeCompare(a.date));
  if(from) list=list.filter(r=>r.date>=from);
  if(to)   list=list.filter(r=>r.date<=to);
  if(prof) list=list.filter(r=>(r.name||'').toLowerCase().includes(prof));

  const el=document.getElementById('hist-list');
  if(!list.length){
    el.innerHTML='<div class="hist-empty"><span>📋</span>Sem registos para os filtros selecionados</div>';
    return;
  }
  el.innerHTML=list.map(r=>{
    const worked=calcWorked(r);
    return `<div class="hist-entry">
      <button class="hist-del" onclick="deleteRecord('${r.date}')">🗑</button>
      <div class="hist-entry-top">
        <div>
          <div class="hist-date">${formatDatePT(r.date)}</div>
          <div class="hist-times">
            ${r.entry?`🟢 Entrada: <b>${r.entry}</b>`:''}
            ${r.lunchout?` &nbsp;🟡 Alm.saída: <b>${r.lunchout}</b>`:''}
            ${r.lunchin?` &nbsp;🟢 Alm.ret.: <b>${r.lunchin}</b>`:''}
            ${r.exit?` &nbsp;🔴 Saída: <b>${r.exit}</b>`:''}
          </div>
          ${r.site?`<div style="font-size:11px;color:var(--accent);margin-top:4px">📍 ${r.site}</div>`:''}
        </div>
        <div class="hist-hours">${worked}</div>
      </div>
      ${r.obs?`<div class="hist-obs">💬 ${r.obs}</div>`:''}
    </div>`;
  }).join('');
}
function formatDatePT(iso){
  const d=new Date(iso+'T12:00:00');
  const days=['Dom','Seg','Ter','Qua','Qui','Sex','Sáb'];
  return `${days[d.getDay()]}, ${String(d.getDate()).padStart(2,'0')}/${String(d.getMonth()+1).padStart(2,'0')}/${d.getFullYear()}`;
}
function calcWorked(r){
  const parse=t=>{if(!t)return null;const[h,m]=t.split(':').map(Number);return h*60+m};
  const e=parse(r.entry),lo=parse(r.lunchout),li=parse(r.lunchin),x=parse(r.exit);
  const total=(e!==null&&x!==null)?x-e:null;
  const lunch=(lo!==null&&li!==null)?li-lo:null;
  const worked=(total!==null)?total-(lunch||0):null;
  if(worked===null)return '--:--';
  return `${String(Math.floor(worked/60)).padStart(2,'0')}:${String(worked%60).padStart(2,'0')}`;
}
function deleteRecord(date){
  records=records.filter(r=>r.date!==date);
  saveRecords();
  updateBadge();
  renderHistory();
  showToast('🗑️ Registo eliminado');
}

// ═══════════════════════════════════════════════════
// EXPORT
// ═══════════════════════════════════════════════════
function exportCSV(){
  if(!records.length){showToast('⚠️ Sem dados para exportar');return;}
  const header='Data,Nome,Local,Entrada,Saída almoço,Retorno almoço,Saída,Horas trabalhadas,Observação\n';
  const rows=records.map(r=>
    `${r.date},"${r.name||''}","${r.site||''}",${r.entry||''},${r.lunchout||''},${r.lunchin||''},${r.exit||''},${calcWorked(r)},"${r.obs||''}"`
  ).join('\n');
  const blob=new Blob(['\uFEFF'+header+rows],{type:'text/csv;charset=utf-8'});
  const url=URL.createObjectURL(blob);
  const a=document.createElement('a');a.href=url;a.download='registos-horas.csv';a.click();
  URL.revokeObjectURL(url);
  showToast('📄 CSV exportado!');
}
function copyReport(){
  if(!records.length){showToast('⚠️ Sem dados');return;}
  const lines=records.slice(0,30).map(r=>
    `📅 ${formatDatePT(r.date)}\n⏱ ${r.entry||'?'}→${r.exit||'?'} | ${calcWorked(r)} trabalhadas${r.obs?'\n💬 '+r.obs:''}`
  );
  const text=`📋 REGISTO DE HORAS\n${profile.name||''} | ${profile.site||''}\n${'─'.repeat(30)}\n${lines.join('\n'+('─'.repeat(30))+'\n')}`;
  navigator.clipboard.writeText(text).then(()=>showToast('📋 Copiado!')).catch(()=>showToast('❌ Erro ao copiar'));
}
function exportWA(){
  if(!records.length){showToast('⚠️ Sem dados');return;}
  const lines=records.slice(0,10).map(r=>
    `📅 ${formatDatePT(r.date)}: ${r.entry||'?'}→${r.exit||'?'} (${calcWorked(r)})${r.obs?' – '+r.obs:''}`
  );
  const text=encodeURIComponent(`📋 REGISTO DE HORAS\n${profile.name||''} | ${profile.site||''}\n${lines.join('\n')}`);
  const wa=profile.wa ? profile.wa.replace(/\D/g,'') : WA_NUMBER;
  window.open(`https://wa.me/${wa}?text=${text}`,'_blank');
}
function sendWA(){
  const obs=document.getElementById('obs-input').value.trim();
  const parts=[];
  if(times.entry)   parts.push(`🟢 Entrada: ${times.entry}`);
  if(times.lunchout)parts.push(`🟡 Saída almoço: ${times.lunchout}`);
  if(times.lunchin) parts.push(`🟢 Retorno: ${times.lunchin}`);
  if(times.exit)    parts.push(`🔴 Saída: ${times.exit}`);
  const worked=calcWorked({entry:times.entry,lunchout:times.lunchout,lunchin:times.lunchin,exit:times.exit});
  const text=encodeURIComponent(`📋 ${profile.name||'—'} | ${profile.site||'—'}\n📅 ${formatDatePT(currentDate)}\n${parts.join('\n')}\n⏱ Total: ${worked}${obs?'\n💬 '+obs:''}`);
  const wa=profile.wa ? profile.wa.replace(/\D/g,'') : WA_NUMBER;
  window.open(`https://wa.me/${wa}?text=${text}`,'_blank');
}

// ═══════════════════════════════════════════════════
// TABS
// ═══════════════════════════════════════════════════
function showTab(tab){
  document.querySelectorAll('.page').forEach(p=>p.classList.remove('active'));
  document.querySelectorAll('.tab-btn').forEach(b=>b.classList.remove('active'));
  document.getElementById('page-'+tab).classList.add('active');
  document.getElementById('tab-'+tab).classList.add('active');
  if(tab==='hist') renderHistory();
}

// ═══════════════════════════════════════════════════
// ALARM
// ═══════════════════════════════════════════════════
let alarmInterval=null;
function initAlarm(){
  document.getElementById('alarm-toggle').checked=alarmCfg.active!==false;
  if(alarmCfg.active!==false) startAlarmPolling();
}
function toggleAlarm(){
  alarmCfg.active=document.getElementById('alarm-toggle').checked;
  saveAlarm();
  if(alarmCfg.active) startAlarmPolling(); else stopAlarmPolling();
  updateAlarmStatus();
}
function startAlarmPolling(){
  if(alarmInterval)return;
  alarmInterval=setInterval(checkAlarm,30000);
  checkAlarm();
}
function stopAlarmPolling(){
  clearInterval(alarmInterval);alarmInterval=null;
}
function checkAlarm(){
  if(!alarmCfg.active) return;
  const now=new Date();
  const day=now.getDay();
  if(day===0||day===6) return; // weekend
  // check silence
  const silence=localStorage.getItem(KEY_SILENCE);
  if(silence===todayISO()) return;
  // check if exit already registered today
  const todayRec=records.find(r=>r.date===todayISO());
  if(todayRec&&todayRec.exit) return;
  // check snooze
  const snoozeTo=alarmCfg.snoozeTo;
  const nowMin=now.getHours()*60+now.getMinutes();
  if(snoozeTo && nowMin<snoozeTo) return;
  // check time: 18:00
  const alarmMin=18*60;
  if(nowMin>=alarmMin && !alarmCfg.triggered){
    alarmCfg.triggered=true;
    saveAlarm();
    showBanner();
    if('Notification' in window && Notification.permission==='granted'){
      new Notification('⏰ Registo de horas',{body:'Não se esqueça de registar a saída!'});
    }
  }
  // reset triggered at midnight (next day)
  if(now.getHours()===0 && now.getMinutes()===0) alarmCfg.triggered=false;
  updateAlarmStatus();
}
function showBanner(){
  document.getElementById('alarm-banner').classList.add('show');
}
function hideBanner(){
  document.getElementById('alarm-banner').classList.remove('show');
}
function alarmSnooze(){
  const now=new Date();
  alarmCfg.snoozeTo=(now.getHours()*60+now.getMinutes())+30;
  alarmCfg.triggered=false;
  saveAlarm();
  hideBanner();
  updateAlarmStatus();
  showToast('😴 Adiado 30 minutos');
}
function alarmRegister(){
  hideBanner();
  showTab('reg');
}
function alarmSilence(){
  localStorage.setItem(KEY_SILENCE,todayISO());
  hideBanner();
  showToast('🔕 Silenciado hoje');
}
function updateAlarmStatus(){
  const el=document.getElementById('alarm-next-text');
  if(!alarmCfg.active){el.textContent='Despertador desligado';return;}
  const silence=localStorage.getItem(KEY_SILENCE);
  if(silence===todayISO()){el.textContent='Silenciado hoje — ativa amanhã';return;}
  if(alarmCfg.snoozeTo){
    const h=Math.floor(alarmCfg.snoozeTo/60),m=alarmCfg.snoozeTo%60;
    el.textContent=`Próximo aviso: hoje às ${String(h).padStart(2,'0')}:${String(m).padStart(2,'0')}`;
  } else {
    el.textContent='Próximo aviso: hoje às 18:00';
  }
}

